{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Write|Edit|Bash|NotebookEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "test -f .claude/ok || { echo '-=- edits are blocked -=-' >&2; exit 2; }"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "rm -f .claude/ok"
                    },
                    {
                        "type": "command",
                        "command": "paplay /x/claude/work.wav"
                    }
                ]
            }
        ]
    },
    "skipDangerousModePermissionPrompt": true,
    "terminalSetTitle": false
}
